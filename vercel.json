{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/hesap.html",
      "dest": "/public/hesap.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
